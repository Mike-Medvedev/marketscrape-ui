    "/scrape": {
      "post": {
        "summary": "Searches Marketplace and returns listings",
        "tags": ["Scrape"],
        "requestBody": {
          "description": "Request body",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "locationId": {
                    "type": "string"
                  },
                  "latitude": {
                    "type": "number",
                    "nullable": true
                  },
                  "longitude": {
                    "type": "number",
                    "nullable": true
                  },
                  "radiusKm": {
                    "type": "number",
                    "nullable": true
                  },
                  "minPrice": {
                    "type": "number",
                    "nullable": true
                  },
                  "pageCount": {
                    "type": "number",
                    "nullable": true
                  },
                  "pageDelayMs": {
                    "type": "number",
                    "nullable": true
                  },
                  "listingFetchDelayMs": {
                    "type": "number",
                    "nullable": true
                  }
                },
                "default": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "listings": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "url": {
                            "type": "string"
                          },
                          "price": {
                            "type": "string"
                          },
                          "title": {
                            "type": "string"
                          },
                          "location": {
                            "type": "string"
                          },
                          "primaryPhotoUri": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "url",
                          "price",
                          "title",
                          "location",
                          "primaryPhotoUri"
                        ]
                      }
                    }
                  },
                  "required": ["listings"]
                }
              }
            }
          }
        }
      }
    },
