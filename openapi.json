      "get": {
        "summary": "List all saved searches",
        "operationId": "getSearches",
        "tags": ["Searches"],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "format": "uuid"
                      },
                      "criteria": {
                        "type": "object",
                        "properties": {
                          "query": {
                            "type": "string"
                          },
                          "location": {
                            "type": "string"
                          },
                          "minPrice": {
                            "type": "string"
                          },
                          "maxPrice": {
                            "type": "string"
                          },
                          "dateListed": {
                            "type": "string",
                            "enum": ["24h", "7d", "30d"]
                          }
                        },
                        "required": [
                          "query",
                          "location",
                          "minPrice",
                          "maxPrice",
                          "dateListed"
                        ]
                      },
                      "settings": {
                        "type": "object",
                        "properties": {
                          "frequency": {
                            "type": "string"
                          },
                          "listingsPerCheck": {
                            "type": "integer",
                            "minimum": 1
                          },
                          "notifications": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "enum": ["email", "sms", "webhook"]
                            }
                          }
                        },
                        "required": [
                          "frequency",
                          "listingsPerCheck",
                          "notifications"
                        ]
                      },
                      "status": {
                        "type": "string",
                        "enum": ["running", "refresh", "error"]
                      },
                      "lastRun": {
                        "type": "string",
                        "nullable": true,
                        "format": "date-time"
                      }
                    },
                    "required": [
                      "id",
                      "criteria",
                      "settings",
                      "status",
                      "lastRun"
                    ]
                  }
                }
              }
            }
          }
        }
